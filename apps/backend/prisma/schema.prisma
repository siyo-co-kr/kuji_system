generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Store {
  id        String   @id @default(uuid())
  name      String
  address   String?
  phone     String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  accounts               Account[]
  events                 Event[]
  prizeCatalogCategories PrizeCatalogCategory[]
  prizeCatalog           PrizeCatalog[]
  displayLayout          DisplayLayout?

  @@map("stores")
}

model Account {
  id                 String   @id @default(uuid())
  storeId            String   @map("store_id")
  email              String   @unique
  passwordHash       String   @map("password_hash")
  name               String   @default("")
  phone              String?
  role               Role     @default(admin)
  isApproved         Boolean  @default(false) @map("is_approved")
  mustChangePassword Boolean  @default(false) @map("must_change_password")
  createdAt          DateTime @default(now()) @map("created_at")

  store Store @relation(fields: [storeId], references: [id])

  @@index([storeId])
  @@map("accounts")
}

enum Role {
  superadmin
  admin
}

model Event {
  id             String      @id @default(uuid())
  storeId        String      @map("store_id")
  title          String
  description    String?
  thumbnailUrl   String?     @map("thumbnail_url")
  totalCount     Int         @map("total_count")
  pricePerUnit   Int         @map("price_per_unit")
  bonusEnabled   Boolean     @default(false) @map("bonus_enabled")
  bonusThreshold Int         @default(10)    @map("bonus_threshold")
  isVisible      Boolean     @default(false) @map("is_visible")
  status         EventStatus @default(draft)
  startedAt      DateTime?   @map("started_at")
  endedAt        DateTime?   @map("ended_at")
  deletedAt      DateTime?   @map("deleted_at")
  createdAt      DateTime    @default(now()) @map("created_at")
  updatedAt      DateTime    @updatedAt      @map("updated_at")

  store       Store        @relation(fields: [storeId], references: [id])
  kujiNumbers KujiNumber[]
  prizes      Prize[]

  @@index([storeId])
  @@index([storeId, status])
  @@index([deletedAt])
  @@map("events")
}

enum EventStatus {
  draft
  active
  closed
}

model KujiNumber {
  id        String    @id @default(uuid())
  eventId   String    @map("event_id")
  number    Int
  isPrize   Boolean   @default(false) @map("is_prize")
  isDrawn   Boolean   @default(false) @map("is_drawn")
  drawnAt   DateTime? @map("drawn_at")
  createdAt DateTime  @default(now()) @map("created_at")

  event       Event        @relation(fields: [eventId], references: [id])
  prizeNumber PrizeNumber?

  @@unique([eventId, number])
  @@index([eventId])
  @@index([eventId, isDrawn])
  @@index([eventId, isPrize])
  @@map("kuji_numbers")
}

model Prize {
  id          String   @id @default(uuid())
  eventId     String   @map("event_id")
  name        String
  description String?
  quantity    Int      @default(1)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt      @map("updated_at")

  event        Event         @relation(fields: [eventId], references: [id])
  images       PrizeImage[]
  prizeNumbers PrizeNumber[]

  @@index([eventId])
  @@map("prizes")
}

model PrizeImage {
  id        String   @id @default(uuid())
  prizeId   String   @map("prize_id")
  imageUrl  String   @map("image_url")
  order     Int      @default(0)
  createdAt DateTime @default(now()) @map("created_at")

  prize Prize @relation(fields: [prizeId], references: [id])

  @@index([prizeId])
  @@map("prize_images")
}

model PrizeNumber {
  id           String @id @default(uuid())
  prizeId      String @map("prize_id")
  kujiNumberId String @unique @map("kuji_number_id")

  prize      Prize      @relation(fields: [prizeId], references: [id])
  kujiNumber KujiNumber @relation(fields: [kujiNumberId], references: [id])

  @@index([prizeId])
  @@map("prize_numbers")
}

// ── 디스플레이 레이아웃 ──────────────────────────────────────

model DisplayLayout {
  id        String   @id @default(uuid())
  storeId   String   @unique @map("store_id")
  slots     Int      @default(2)
  viewMode  String   @default("multi") @map("view_mode")
  updatedAt DateTime @updatedAt @map("updated_at")

  store      Store         @relation(fields: [storeId], references: [id])
  slotEvents DisplaySlot[]

  @@map("display_layouts")
}

model DisplaySlot {
  id        String  @id @default(uuid())
  layoutId  String  @map("layout_id")
  slotIndex Int     @map("slot_index")
  eventId   String? @map("event_id")

  layout DisplayLayout @relation(fields: [layoutId], references: [id], onDelete: Cascade)

  @@unique([layoutId, slotIndex])
  @@index([layoutId])
  @@map("display_slots")
}

// ── 경품 카탈로그 ────────────────────────────────────────────

model PrizeCatalogCategory {
  id        String   @id @default(uuid())
  storeId   String   @map("store_id")
  name      String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt      @map("updated_at")

  store  Store          @relation(fields: [storeId], references: [id])
  prizes PrizeCatalog[]

  @@index([storeId])
  @@map("prize_catalog_categories")
}

model PrizeCatalog {
  id          String   @id @default(uuid())
  storeId     String   @map("store_id")
  categoryId  String?  @map("category_id")
  name        String
  description String?
  imageUrl    String?  @map("image_url")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt      @map("updated_at")

  store    Store                 @relation(fields: [storeId], references: [id])
  category PrizeCatalogCategory? @relation(fields: [categoryId], references: [id])

  @@index([storeId])
  @@index([categoryId])
  @@map("prize_catalog")
}

model Notice {
  id        String   @id @default(uuid())
  title     String
  content   String
  isPinned  Boolean  @default(false) @map("is_pinned")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt      @map("updated_at")

  @@map("notices")
}
