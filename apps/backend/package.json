    "@prisma/client": "^6.8.2",
    "@kuji/types": "workspace:*",
    "bcryptjs": "^3.0.2",
    "fastify": "^5.3.2",
    "fastify-plugin": "^5.0.1",
    "fastify-socket.io": "^5.0.0",
    "redis": "^4.7.0",
    "socket.io": "^4.8.1",
    "zod": "^3.25.46"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
